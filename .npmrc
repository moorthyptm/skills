# Supply-chain hardening — see https://docs.npmjs.com/cli/v11/configuring-npm/npmrc

# Always audit; fail install on moderate+ vulnerabilities
audit=true
audit-level=moderate

# Pin new installs to exact versions (no ^ or ~) so npm install never
# silently bumps a transitive dep when a malicious patch ships.
save-exact=true

# Always generate / honour package-lock.json — reproducible installs
package-lock=true

# Enforce the `engines` field in package.json
engine-strict=true

# Quieter output
fund=false
update-notifier=false
loglevel=warn

# IMPORTANT — manual upgrade policy
# Run `npm run upgrade:safe` (not bare `npm update`) to upgrade.
# It uses `npm update --before "<7 days ago>"` so freshly-published
# (potentially compromised) versions are skipped until they've been
# in the wild for a week.
