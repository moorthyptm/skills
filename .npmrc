# Supply-chain hardening — see https://docs.npmjs.com/cli/v11/using-npm/config/

# Always audit; fail install on moderate+ vulnerabilities
audit=true
audit-level=moderate

# Pin new installs to exact versions (no ^ or ~) so npm install never
# silently bumps a transitive dep when a malicious patch ships.
save-exact=true

# Always generate / honour package-lock.json — reproducible installs
package-lock=true

# Enforce the `engines` field in package.json
engine-strict=true

# Quieter output
fund=false
update-notifier=false
loglevel=warn

# Cooling-off window — only install versions published >7 days ago.
# Native to npm 11.10+ (older npm silently ignores this).
# Defends against the window where a compromised release is live but
# hasn't been caught and pulled yet. Pairs with pnpm/bun's
# minimumReleaseAge / --minimum-release-age.
min-release-age=7
